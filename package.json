{
  "name": "pokedex",
  "version": "1.0.0",
  "main": "node_modules/expo/AppEntry.js",
  "scripts": {
    "postinstall": "node scripts/patch-ios-unicode.js",
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "prebuild": "expo prebuild --clean",
    "test": "jest --watchAll",
    "test:ci": "jest --ci",
    "lint": "expo lint",
    "clean": "rm -rf node_modules .expo ios android && rm -rf ~/Library/Developer/Xcode/DerivedData/*",
    "clean:ios": "rm -rf ios && rm -rf ~/Library/Developer/Xcode/DerivedData/*",
    "clean:android": "rm -rf android",
    "fresh-install": "npm run clean && npm install",
    "setup:ios": "npm run clean:ios && npm install && npx expo prebuild --clean --platform ios --no-install && cd ios && BUNDLE_GEMFILE=../Gemfile bundle install && BUNDLE_GEMFILE=../Gemfile bundle exec pod install --repo-update",
    "setup:ios:device": "npm run setup:ios && npx expo run:ios --device",
    "setup:android": "npm run clean:android && npm install && npx expo prebuild --clean --platform android && rm -rf node_modules/react-native-mmkv/android/.cxx && cd android && ./gradlew clean && ./gradlew :react-native-nitro-modules:externalNativeBuildDebug -PreactNativeArchitectures=x86_64,arm64-v8a && cd ..",
    "setup:android:device": "npm run setup:android && npx expo run:android --device",
    "ios:prebuild": "npx expo prebuild --platform ios --clean",
    "ios:increment-build": "node scripts/increment-build.js ios",
    "android:prebuild": "npx expo prebuild --platform android --clean",
    "android:bundle": "cd android && ./gradlew bundleRelease",
    "android:increment-build": "node scripts/increment-build.js android",
    "e2e:build:ios": "detox build --configuration ios.sim.debug",
    "e2e:test:ios": "detox test --configuration ios.sim.debug",
    "e2e:build:ios:release": "detox build --configuration ios.sim.release",
    "e2e:test:ios:release": "detox test --configuration ios.sim.release --cleanup",
    "e2e:build:android": "detox build --configuration android.emu.debug",
    "e2e:test:android": "detox test --configuration android.emu.debug",
    "e2e:test:ios:record": "detox test --configuration ios.sim.debug --record-videos all --artifacts-location ./e2e/artifacts",
    "e2e": "bash scripts/e2e.sh",
    "e2e:suite": "bash scripts/e2e.sh"
  },
  "dependencies": {
    "@expo-google-fonts/bricolage-grotesque": "^0.4.0",
    "@expo-google-fonts/nunito": "^0.4.0",
    "@react-navigation/native": "^7.1.33",
    "@react-navigation/native-stack": "^7.14.4",
    "@reduxjs/toolkit": "^2.11.2",
    "axios": "^1.13.6",
    "expo": "~55.0.5",
    "expo-font": "~13.0.1",
    "expo-status-bar": "~55.0.4",
    "expo-system-ui": "~55.0.9",
    "react": "19.2.4",
    "react-native": "0.83.2",
    "react-native-gesture-handler": "~2.30.0",
    "react-native-mmkv": "^4.2.0",
    "react-native-nitro-modules": "^0.35.0",
    "react-native-reanimated": "~4.2.1",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.23.0",
    "react-native-worklets": "^0.7.4",
    "react-redux": "^9.2.0"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@config-plugins/detox": "^11.0.0",
    "@testing-library/react-native": "^13.3.3",
    "@types/react": "~19.2.2",
    "babel-jest": "^29.7.0",
    "babel-plugin-module-resolver": "^5.0.2",
    "detox": "^20.26.0",
    "jest": "^29.7.0",
    "jest-circus": "^29.7.0",
    "jest-expo": "~55.0.9",
    "react-test-renderer": "19.2.4",
    "typescript": "~5.9.2"
  },
  "jest": {
    "preset": "jest-expo",
    "setupFiles": [
      "./jest.setup.js"
    ],
    "moduleNameMapper": {
      "^react-native-mmkv$": "<rootDir>/__mocks__/react-native-mmkv.js",
      "^react-native-reanimated$": "<rootDir>/__mocks__/react-native-reanimated.js",
      "^react-native-reanimated/.*$": "<rootDir>/__mocks__/react-native-reanimated.js",
      "^@expo/vector-icons$": "<rootDir>/__mocks__/@expo/vector-icons.js",
      "^@expo/vector-icons/.*$": "<rootDir>/__mocks__/@expo/vector-icons.js"
    },
    "transformIgnorePatterns": [
      "node_modules/(?!((jest-)?react-native|@react-native(-community)?)|expo(nent)?|@expo(nent)?/.*|react-navigation|@react-navigation/.*|react-native-mmkv|@reduxjs|react-redux|immer)"
    ]
  }
}
